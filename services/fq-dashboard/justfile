# fq-dashboard build tasks (the operator dashboard BFF).

set positional-arguments

# Build the crate.
build:
    cargo build

# Check formatting
fmt-check:
    cargo fmt --check

# Clippy lints (Cargo.toml denies all warnings).
lint:
    cargo clippy --all-targets

# Run tests, or forward cargo args. Hermetic: the router tests spin
# their own read service over a temp DB; no broker, no daemon.
test *args:
    cargo test "$@"

# Build the docs with warnings denied — catches broken intra-doc links.
doc:
    RUSTDOCFLAGS="-D warnings" cargo doc --no-deps

# Phases are timed individually (#223) so a slow run says *which* step is slow.
# Timers live here, where the phases are, rather than in the root `ci` recipe,
# which delegates to this target and must not re-inline it (#196).
#
# `build` front-loads the test-binary codegen `cargo test` would do anyway, so
# `test` measures test *execution*. It adds no net work.
#
# Nested under the root gate the phases join its summary; run standalone (as CI
# does) this prints its own. See scripts/ci-timing.sh.
# All quality checks — hermetic, no external services required.
ci:
    #!/usr/bin/env bash
    set -uo pipefail
    # Anchored on this justfile's directory, so a standalone run logs to the
    # repo root like the root gate does. An inherited value wins — nested under
    # the root gate, append to its log rather than start our own (#223).
    export FQ_CI_TIMINGS="${FQ_CI_TIMINGS:-{{justfile_directory()}}/../../.ci-timings}"
    source {{justfile_directory()}}/../../scripts/ci-timing.sh
    ci_timing_init
    run_phase "fmt-check" just fmt-check
    run_phase "lint"      just lint
    run_phase "doc"       just doc
    run_phase "build"     cargo build --tests
    run_phase "test"      just test
