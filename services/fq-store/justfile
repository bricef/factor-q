# fq-store build tasks (content-addressed storage + index service).

set positional-arguments

# Build the crate. `cli,service` matches the hermetic `test` path: the fq-cas
# binary and tarpc service, without the NATS-backed `bus` feature.
build:
    cargo build --features cli,service

# Check formatting
fmt-check:
    cargo fmt --check

# Clippy lints (Cargo.toml denies all warnings); --all-features covers the CLI.
lint:
    cargo clippy --all-targets --all-features

# Run tests, or forward cargo args (e.g. `just test conformance`). Hermetic:
# `cli,service` builds the fq-cas binary and tarpc service without pulling in
# the `bus` feature, whose grant-bus integration test needs a live NATS broker.
test *args:
    cargo test --features cli,service "$@"

# The NATS-backed grant-bus integration test. It spawns its own private
# nats-server (#233) — no shared broker needed — so it just needs the pinned
# binary `just install-nats` drops in .tools/ at the repo root. Part of `ci`
# below (the root `store-ci` provisions the binary via its `install-nats`
# dependency); kept callable on its own for a quick bus-only loop.
test-bus:
    FQ_TEST_NATS_SERVER="${FQ_TEST_NATS_SERVER:-{{justfile_directory()}}/../../.tools/nats-server}" cargo test --features bus --test grant_bus

# Adversarial interleaving tests driven through the fail-crate seams (the
# concurrency verification plan). Hermetic, but separate from `test` so the
# `failpoints` feature — which activates the protocol-step seams — is only
# compiled in where they're actually driven.
test-failpoints:
    cargo test --features failpoints --test gc_interleaving

# Build the docs with warnings denied — catches broken intra-doc links.
# `--all-features` type-checks the `bus` code too (compiling needs no broker).
doc:
    RUSTDOCFLAGS="-D warnings" cargo doc --no-deps --all-features

# Phases are timed individually (#223) so a slow run says *which* step is slow.
# Timers live here, where the phases are, rather than in the root `ci` recipe,
# which delegates to this target and must not re-inline it (#196).
#
# `build` front-loads the test-binary codegen `cargo test` would do anyway, so
# `test` measures test *execution*. It carries the same `cli,service` features
# as `test` — matching the hermetic path, no `bus`, no broker needed.
#
# `doctest` is split out because it cannot be front-loaded: rustdoc compiles
# doctests at run time, so their build cost is irreducible and, left inside
# `test`, reads as test execution. Its own phase makes it visible.
#
# `--tests` selects every target with `test = true` — lib and bin unittests plus
# integration tests — which is `cargo test`'s default set minus doctests (no
# examples here, so nothing is dropped). Benches default to `test = false`, so
# the throughput bench stays out; NOT --all-targets, which adds --benches and
# would run that benchmark (harness = false) as part of the gate.
#
# Nested under the root gate the rows join its summary; run standalone (as CI
# does) this prints its own. See scripts/ci-timing.sh.
# All quality checks. The final phase (`test-bus`) spawns private brokers
# (#233) and so needs the pinned nats-server — root `just store-ci` provisions
# it; a bare `just ci` here panics with install instructions if it is missing.
ci:
    #!/usr/bin/env bash
    set -uo pipefail
    # Anchored on this justfile's directory, so a standalone run logs to the
    # repo root like the root gate does. An inherited value wins — nested under
    # the root gate, append to its log rather than start our own (#223).
    export FQ_CI_TIMINGS="${FQ_CI_TIMINGS:-{{justfile_directory()}}/../../.ci-timings}"
    source {{justfile_directory()}}/../../scripts/ci-timing.sh
    ci_timing_init
    run_phase "fmt-check" just fmt-check
    run_phase "lint"      just lint
    run_phase "doc"       just doc
    run_phase "build"     cargo build --tests --features cli,service
    run_phase "test"      just test --tests
    run_phase "doctest"   just test --doc
    run_phase "failpoints" just test-failpoints
    run_phase "test-bus"  just test-bus
