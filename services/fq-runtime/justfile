# fq-runtime build tasks

# Enable "$@" in recipe bodies so variadic *args preserve shell quoting.
set positional-arguments

# The bus/integration tests need a NATS endpoint. Default to the local
# dev instance (`just infra-up`); override by exporting FQ_NATS_URL in
# the environment before invoking just.
# The dev broker requires token auth (infrastructure/nats/nats.conf);
# the credential rides in the URL userinfo (see bus.rs
# url_credentials).
export FQ_NATS_URL := env_var_or_default("FQ_NATS_URL", "nats://fq-dev-token@127.0.0.1:4222")

# Show available recipes
default:
    @just --list

# Build the workspace
build:
    cargo build

# Build in release mode
build-release:
    cargo build --release

# Run all tests, or a filtered subset by forwarding cargo args
# (e.g. `just test -p fq-runtime --lib agent::definition`).
test *args:
    cargo test "$@"

# Type-check without building. --all-targets covers tests and
# examples, matching the workspace lint policy.
check:
    cargo check --all-targets

# Format code
fmt:
    cargo fmt

# Check formatting without modifying files
fmt-check:
    cargo fmt --check

# Run clippy lints. The workspace already denies warnings via
# `[workspace.lints]` in Cargo.toml; `--all-targets` ensures the
# check covers test and example code too.
lint:
    cargo clippy --all-targets -- -D warnings

# Clean build artefacts
clean:
    cargo clean

# Run the fq CLI (e.g. `just fq --agents-dir ./agents agent list`)
#
# Preserves the user's invocation directory so relative paths in
# arguments resolve against the directory where the user invoked `just`,
# not the justfile directory.
#
# Uses "$@" (enabled by `set positional-arguments`) so quoted arguments
# are forwarded to fq intact.
[no-cd]
fq *args:
    cargo run --quiet --manifest-path {{justfile_directory()}}/Cargo.toml --bin fq -- "$@"

# Build the docs with warnings denied — catches broken intra-doc links.
doc:
    RUSTDOCFLAGS="-D warnings" cargo doc --no-deps

# Phases are timed individually (#223) so a slow run says *which* step is slow —
# clippy, rustdoc, and test codegen are separately actionable. Timers live here,
# where the phases are, rather than in the root `ci` recipe, which delegates to
# this target and must not re-inline it (#196).
#
# `build` front-loads the test-binary codegen that `cargo test` would do anyway,
# so `test` measures test *execution*. It adds no net work.
#
# Nested under the root gate the rows join its summary; run standalone (as CI
# does) this prints its own. See scripts/ci-timing.sh.
# Run all quality checks
ci:
    #!/usr/bin/env bash
    set -uo pipefail
    # Anchored on this justfile's directory, so a standalone run logs to the
    # repo root like the root gate does. An inherited value wins — nested under
    # the root gate, append to its log rather than start our own (#223).
    export FQ_CI_TIMINGS="${FQ_CI_TIMINGS:-{{justfile_directory()}}/../../.ci-timings}"
    source {{justfile_directory()}}/../../scripts/ci-timing.sh
    ci_timing_init
    run_phase "fmt-check" just fmt-check
    run_phase "lint"      just lint
    run_phase "doc"       just doc
    run_phase "build"     cargo build --tests
    run_phase "test"      just test

# Drift detector against the live Anthropic API. Sends one short
# Haiku call (~fractions of a cent) and asserts the response
# parses through our genai adapter. Use this when the mock-server
# tests pass but you want to confirm the real wire contract is
# unchanged — typically after Anthropic ships a model or API
# update. Requires ANTHROPIC_API_KEY in the environment.
acceptance-drift:
    cargo test -- --ignored anthropic_real_api

# Build the fq-runtime container image
docker-build:
    docker build -t factor-q/fq-runtime:latest .

# Run the fq-tools shell sandbox tests inside a disposable
# container with networking disabled. The shell tool spawns child
# processes, and even though the tests use safe commands we want
# the blast radius contained to a throwaway container while we're
# iterating on the sandbox. The workspace is mounted read-only;
# the image has a primed cargo registry and /target cache so the
# run can proceed offline.
test-shell-sandbox:
    docker build -t factor-q/shell-test -f Dockerfile.shell-test .
    docker run --rm --network none \
        -v {{justfile_directory()}}:/src:ro \
        factor-q/shell-test

# Deep verification soak (reducer verification plan, slice 7): the
# randomised lifecycle driver with every oracle on. CI runs 48
# scenarios inside the normal test suite; this recipe scales the
# iteration count for local bug-hunting (~3 min per 1000).
soak iters="1000":
    FQ_SOAK_ITERS={{iters}} cargo test -p fq-runtime --lib soak_fixed -- --nocapture
