            "format": "uint32",
            "default": null,
            "minimum": 0
          }
        },
        "required": [
          "invocation_id"
        ]
      }
    }
  },
  {
    "resource": {
      "domain": "invocation",
      "nature": "view",
      "version": 1,
      "description": "exemplar resource",
      "stability": "experimental",
