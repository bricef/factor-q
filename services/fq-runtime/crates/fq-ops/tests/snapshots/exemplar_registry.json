      "version": 1,
      "description": "exemplar resource",
      "stability": "experimental",
      "key_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "EntryKey",
        "type": "object",
        "properties": {
          "seq": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          }
        },
        "required": [
          "seq"
        ]
      },
      "state_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "EntryState",
        "type": "object",
