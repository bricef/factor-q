        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "InvocationKey",
        "type": "object",
        "properties": {
          "invocation_id": {
            "type": "string"
          }
        },
        "required": [
          "invocation_id"
        ]
      },
      "state_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
