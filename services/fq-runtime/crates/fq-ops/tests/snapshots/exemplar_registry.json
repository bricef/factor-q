          },
          "round": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "seq": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          }
        },
        "required": [
          "seq",
          "invocation_id",
          "round",
          "role",
          "content"
