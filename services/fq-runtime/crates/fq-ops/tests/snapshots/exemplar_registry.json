            "type": [
              "integer",
              "null"
            ],
            "format": "uint32",
            "default": null,
            "minimum": 0
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          }
        }
      }
    }
  },
  {
    "resource": {
      "domain": "trigger",
      "nature": "atom",
      "version": 1,
      "description": "exemplar resource",
      "stability": "experimental",
      "key_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "TriggerKey",
        "type": "object",
        "properties": {
          "seq": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          }
        },
        "required": [
          "seq"
        ]
      },
      "state_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "TriggerState",
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "payload": true,
          "seq": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          }
        },
        "required": [
          "seq",
          "agent_id",
          "payload"
        ]
      },
      "filter_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "TriggerFilter",
        "type": "object",
        "properties": {
          "agent_id": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          }
        }
      }
    }
  },
  {
    "resource": {
      "domain": "control",
      "nature": "synthetic",
      "version": 1,
      "description": "exemplar resource",
      "stability": "experimental",
      "key_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "null",
        "type": "null"
      },
      "state_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "ControlState",
