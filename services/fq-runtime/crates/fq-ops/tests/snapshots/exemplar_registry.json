            "type": "boolean"
          },
          "stream_ok": {
            "type": "boolean"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "version",
          "nats_connected",
          "stream_ok"
        ]
      },
      "filter_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "null",
        "type": "null"
      }
    }
  },
  {
    "command": {
      "domain": "invocation",
      "verb": "drop",
      "version": 1,
      "authority": {
        "verb": "write",
        "scope": "invocation"
      },
      "description": "Drop an in-flight invocation, archiving it as failed. Kill-switch semantics: workers observe the drop at their next step boundary.",
      "stability": "experimental",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "DropInput",
        "type": "object",
        "properties": {
          "invocation_id": {
            "type": "string"
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "invocation_id"
        ]
      }
    }
  },
  {
    "command": {
      "domain": "control",
      "verb": "down",
      "version": 1,
      "authority": {
        "verb": "write",
        "scope": "control"
      },
      "description": "Stop the daemon, draining in-flight work to a step boundary. Confirmation is the shutdown event, not the ack.",
      "stability": "experimental",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "DownInput",
        "type": "object",
        "properties": {
          "now": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  },
  {
    "command": {
      "domain": "trigger",
      "verb": "publish",
      "version": 1,
      "authority": {
        "verb": "write",
        "scope": "trigger"
      },
      "description": "Dispatch a trigger to an agent via the durable trigger stream. At-least-once delivery with a bounded budget; the receipt references the appended trigger atom.",
      "stability": "experimental",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "PublishInput",
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "payload": true
        },
        "required": [
          "agent_id",
          "payload"
        ]
      }
    }
  },
  {
    "report": {
      "name": "cost.summary",
      "version": 1,
      "reads": [
        "event"
      ],
      "description": "Aggregate cost across all agents. Cost figures are retained indefinitely; totals never window.",
      "stability": "experimental",
      "params_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "CostParams",
        "type": "object",
        "properties": {
          "since": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          }
        }
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "CostOutput",
        "type": "object",
        "properties": {
          "total_cost": {
            "type": "number",
            "format": "double"
          },
          "total_llm_calls": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          }
        },
        "required": [
          "total_cost",
          "total_llm_calls"
        ]
      }
    }
  }
]
