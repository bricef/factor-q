[
  {
    "op": {
      "invocation": "drop"
    },
    "name": "invocation.drop",
    "version": 1,
    "kind": "command",
    "meta": {
      "permission": {
        "verb": "write",
        "scope": "invocation"
      },
      "stability": "experimental",
      "caveats": "kill-switch semantics: the invocation is archived as failed; workers observe the drop at their next step boundary"
    },
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "DropInput",
      "type": "object",
      "properties": {
        "invocation_id": {
          "type": "string"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "invocation_id"
      ]
    },
    "output_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Receipt",
      "description": "A command's output: references to the events it appended, never\nstate (D3, P4). Freshness is the caller's to compose — a receipt's\nwatermark feeds the next query's `min_seq` for read-your-writes.",
      "type": "object",
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EventRef"
          }
        }
      },
      "required": [
        "events"
      ],
      "$defs": {
        "EventRef": {
          "description": "Reference to one event a command appended (D3): subject, stream,\nand the event-log sequence — which is also the universal cursor\n(P5).",
          "type": "object",
          "properties": {
            "seq": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "stream": {
              "type": "string"
            },
            "subject": {
              "type": "string"
            }
          },
          "required": [
            "subject",
            "stream",
            "seq"
          ]
        }
      }
    }
  },
  {
