# Release packaging output (`just package` / scripts/package.sh).
/dist/

# TLA+ / TLC model-checker scratch output (docs/design/storage_gc.tla).
docs/design/states/

# Local secrets — provider API keys for end-to-end LLM testing (never commit).
.env
.env.*
!.env.example

# Claude Code agent scratch — git worktrees and write-tracking. Never
# tracked; ignoring it also keeps the working tree clean so release
# builds stamp a bare commit SHA (not "<sha>-dirty").
.claude/

# Pinned dev/test tooling fetched by `just install-nats` (#233) — a binary,
# and reproducible from .nats-version, so it is never committed.
/.tools/

# `just ci`'s phase log (scripts/ci-timing.sh, #223). Truncated by each run and
# left behind on purpose: after a killed run it is the only record of where the
# time went. Anchored — every gate anchors the log on {{justfile_directory()}},
# so it is always this one file, never a stray copy in a service directory.
/.ci-timings

# TLC model-checker scratch output
docs/design/committed/states/
